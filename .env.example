# ==========================================
# APGB_SYSTEM (Porto Cais) - Variáveis de Ambiente
# ==========================================
# Crie uma cópia deste ficheiro como .env para uso local

# 1. Configurações Gerais
NODE_ENV=production
PORT=4000
VITE_API_BASE_URL=https://apgb-system.onrender.com

# 2. Configuração de Banco de Dados (PostgreSQL)
# Render fornecerá esta URL automaticamente nos serviços vinculados, 
# mas pode ser definida manualmente se usar um DB externo.
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# 3. Segurança e Autenticação
# Gere uma chave forte (ex: openssl rand -base64 32)
JWT_SECRET=super_secret_key_change_in_production
BCRYPT_SALT_ROUNDS=10

# 4. CORS (Cross-Origin Resource Sharing)
# Domínio do frontend para permitir requests. Use * para permitir todos.
CORS_ORIGIN=https://apgb-system-frontend.onrender.com
